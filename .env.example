# =====================================================================
# env.example — copy to .env and fill in real values
# =====================================================================

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YourPasswordHere
NEO4J_DATABASE=neo4j
NEO4J_CONNECTION_TIMEOUT_SECONDS=5

# Weaviate
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=18080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=PolicyChunk

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ── Main Groq (response generation) ──────────────────────────────────
# Used for response generation and LLM fallback in intent/entity detection.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# ── Planner Groq (SEPARATE account — must differ from GROQ_API_KEY) ──
# Leave empty to disable the LLM planner (system uses fixed routing).
PLANNER_GROQ_API_KEY=
PLANNER_MODEL=openai/gpt-oss-20b
PLANNER_REASONING_EFFORT=low
PLANNER_MAX_TOKENS=180
PLANNER_TEMPERATURE=0
PLANNER_MIN_CONFIDENCE=0.75
PLANNER_TIMEOUT_SECONDS=5

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# Loop limits
MAX_ITERATIONS=5
MAX_TOOL_CALLS=4
MAX_SAME_TOOL_CALLS=1

# Conversation state (seconds)
CONVERSATION_TTL_SECONDS=900

# Retrieval
HYBRID_ALPHA=0.5
RETRIEVAL_TOP_K=4
RETRIEVAL_MIN_SCORE=0.15
EVALUATION_METADATA_ENABLED=false
READINESS_TIMEOUT_SECONDS=3

# Data paths (relative to project root)
PROCESSED_DIR=data/processed
SEED_DIR=data/seed
POLICIES_DIR=data/policies
BUSINESS_RULES_PATH=business_rules.yaml
