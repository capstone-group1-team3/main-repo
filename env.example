# =========================================================
# .env.example  -  copy to .env and fill in your values
# =========================================================

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YourPasswordHere
NEO4J_DATABASE=neo4j

# Weaviate (HTTP port is 18080 - matches docker-compose)
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=18080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=PolicyChunk

# Embeddings (BGE-M3 - runs in-process on CPU)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# Main Groq LLM (intent/entity fallback + response generation)
# Get your key at https://console.groq.com
GROQ_API_KEY=your_main_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b

# Planner Groq LLM (separate account + separate key)
# Used only for the Hybrid Planner. If absent, the system falls back to
# deterministic fixed routing automatically.
PLANNER_GROQ_API_KEY=your_planner_groq_api_key_here
PLANNER_MODEL=llama-openai/gpt-oss-20b
PLANNER_REASONING_EFFORT=low
PLANNER_MAX_TOKENS=180
PLANNER_TEMPERATURE=0
PLANNER_MIN_CONFIDENCE=0.75
PLANNER_TIMEOUT_SECONDS=5

# Auth
# Change JWT_SECRET in production - use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# Orchestrator loop limits
MAX_ITERATIONS=5
MAX_TOOL_CALLS=4
MAX_SAME_TOOL_CALLS=1

# Retrieval
HYBRID_ALPHA=0.5
RETRIEVAL_TOP_K=4

# Data paths (relative to repo root)
PROCESSED_DIR=data/processed
SEED_DIR=data/seed
POLICIES_DIR=data/policies
BUSINESS_RULES_PATH=business_rules.yaml
